{
  "name": "inventory-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "config": "node src/environments/set-env.js",
    "dev": "npm run config && ng serve",
    "start": "serve -s dist/inventory-frontend/browser -l tcp://0.0.0.0:${PORT:-8080}",
    "build": "npm run config && ng build --configuration production",
    "watch": "npm run config && ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.5.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "chart.js": "^4.5.1",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.0",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.0",
    "dotenv": "^17.4.2",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}